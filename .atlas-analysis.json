  "keyFeatures": [
    "WhatsApp conversational interface with intelligent state machine",
    "Multi-tier memory system (immediate, session, episodic, semantic)",
    "Hallucination detection for LLM responses",
    "OCR for document extraction (DNI, marriage certificates)",
    "Admin dashboard for case management",
    "Legal document generation (PDF petitions)",
    "Rate limiting and security headers",
    "Clean Architecture implementation with SOLID principles"
  ],
  "publicApiSurface": [
    "POST /webhook/whatsapp - Process incoming WhatsApp messages",
    "POST /api/auth/login - Authenticate operators",
    "GET /api/cases/ - List divorce cases",
    "GET /api/cases/{id} - Get case details",
    "PATCH /api/cases/{id} - Update case",
    "POST /api/cases/{id}/documents/request - Request documents from user",
    "POST /api/cases/{id}/pdf/generate - Generate legal petition PDF",
    "GET /api/metrics/summary - System metrics",
    "GET /health/ - Health check endpoint",
    "ProcessIncomingMessageUseCase - Main message processing use case",
    "ConversationEngine - State machine and flow handler",
    "MemoryService - Contextual memory management",
    "HallucinationDetectionService - Response validation",
    "MultiProviderOCRService - Document OCR processing"
  ]
}
